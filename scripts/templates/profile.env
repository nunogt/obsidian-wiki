# Profile: {NAME}
# Materialized from scripts/templates/profile.env by kb-contexts-regenerate.
# Do not edit this file directly — edit profiles/{NAME}.env or the template.

OBSIDIAN_VAULT_PATH={GIT_ROOT}/kb-{NAME}

# OBSIDIAN_SOURCES_DIR left empty by default; material enters via scp to
# the vault's _raw/ staging dir. Point at a sources directory later if
# you want bulk-ingest capability. Comma-separated for multiple paths.
#
# Multi-vault recommendation: keep external research INSIDE this vault
# under _sources/ (per-vault containment, no cross-vault contamination):
#   OBSIDIAN_SOURCES_DIR={GIT_ROOT}/kb-{NAME}/_sources
OBSIDIAN_SOURCES_DIR=

# Vault-relative subset of OBSIDIAN_SOURCES_DIR that lives INSIDE this
# vault. Tells the fork's vault-scanning skills (cross-linker, tag-taxonomy,
# wiki-export, wiki-lint, wiki-status, wiki-ingest) to exclude it — so
# source files aren't treated as wiki pages. Set to "_sources" if you
# follow the multi-vault recommendation above.
OBSIDIAN_INVAULT_SOURCES_DIR=

OBSIDIAN_CATEGORIES=concepts,entities,skills,references,synthesis,journal
OBSIDIAN_RAW_DIR=_raw
OBSIDIAN_MAX_PAGES_PER_INGEST=15

# QMD semantic search — leave empty for Grep fallback
QMD_WIKI_COLLECTION=
QMD_PAPERS_COLLECTION=

# Lint schedule: informational only; no cron wired
LINT_SCHEDULE=weekly
